BlogSource-Repository &amp;mdash;提交后github action 自动编译 , push 到 &amp;ndash;&amp;gt; BlogBuildOut-Repository&lt;br&gt;
但是这个过程中CNAME 会被删除。为了保证域名稳定。&lt;br&gt;
将 CNAME 存储在 BlogSource-Repository&lt;/p&gt;
&lt;ol&gt;
&lt;li&gt;创建 CNAME 记录域名： &lt;code&gt;echo &amp;quot;example.com&amp;quot; &amp;gt; static/CNAME&lt;/code&gt;&lt;/li&gt;
&lt;li&gt;配置 hugo config&lt;/li&gt;
&lt;/ol&gt;
&lt;pre tabindex="0"&gt;&lt;code&gt;staticDir = [&amp;#39;static&amp;#39;, &amp;#39;content/resource/image/blog&amp;#39;]


[outputs]
 home = [&amp;#34;HTML&amp;#34;]

[mediaTypes]
 [mediaTypes.&amp;#34;text/plain&amp;#34;]
 suffixes = [&amp;#34;CNAME&amp;#34;]

[outputFormats.CNAME]
 baseName = &amp;#34;CNAME&amp;#34;
 isPlainText = true
 mediaType = &amp;#34;text/plain&amp;#34;
 permalinkable = false
 rel = &amp;#34;canonical&amp;#34;
&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;


