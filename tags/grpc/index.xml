<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>GRPC on Hugo Theme Tailwind Example Site</title><link>https://cuisiting.github.io/tags/grpc/</link><description>Recent content in GRPC on Hugo Theme Tailwind Example Site</description><generator>Hugo</generator><language>en</language><copyright>Cuisiting</copyright><lastBuildDate>Tue, 30 Jan 2024 00:00:00 +0000</lastBuildDate><atom:link href="https://cuisiting.github.io/tags/grpc/index.xml" rel="self" type="application/rss+xml"/><item><title>数据格式</title><link>https://cuisiting.github.io/posts/%E6%95%B0%E6%8D%AE%E6%A0%BC%E5%BC%8F/</link><pubDate>Tue, 30 Jan 2024 00:00:00 +0000</pubDate><guid>https://cuisiting.github.io/posts/%E6%95%B0%E6%8D%AE%E6%A0%BC%E5%BC%8F/</guid><description>&lt;p&gt;&lt;strong&gt;二进制数据格式&lt;/strong&gt;：&lt;/p&gt;
&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th&gt;数据格式&lt;/th&gt;
 &lt;th&gt;特点&lt;/th&gt;
 &lt;th&gt;适用场景&lt;/th&gt;
 &lt;th&gt;使用服务/应用程序&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td&gt;Avro&lt;/td&gt;
 &lt;td&gt;二进制格式，高性能，模式定义&lt;/td&gt;
 &lt;td&gt;大数据处理，分布式系统&lt;/td&gt;
 &lt;td&gt;Apache Hadoop，Kafka&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;Protocol Buffers&lt;/td&gt;
 &lt;td&gt;二进制格式，高性能，代码生成&lt;/td&gt;
 &lt;td&gt;分布式系统，网络通信，高性能数据交换&lt;/td&gt;
 &lt;td&gt;gRPC，Google APIs&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;MessagePack&lt;/td&gt;
 &lt;td&gt;二进制格式，紧凑，多语言支持&lt;/td&gt;
 &lt;td&gt;数据存储，通信，高性能应用程序&lt;/td&gt;
 &lt;td&gt;Redis，MessagePack-RPC&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;BSON&lt;/td&gt;
 &lt;td&gt;二进制JSON扩展，高性能，数据类型支持&lt;/td&gt;
 &lt;td&gt;NoSQL数据库，MongoDB数据交换&lt;/td&gt;
 &lt;td&gt;MongoDB&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;
&lt;p&gt;&lt;strong&gt;文本数据格式&lt;/strong&gt;：&lt;/p&gt;
&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th&gt;数据格式&lt;/th&gt;
 &lt;th&gt;特点&lt;/th&gt;
 &lt;th&gt;适用场景&lt;/th&gt;
 &lt;th&gt;使用服务/应用程序&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td&gt;JSON&lt;/td&gt;
 &lt;td&gt;文本格式，易于阅读，易于编写&lt;/td&gt;
 &lt;td&gt;Web应用程序，API，配置文件&lt;/td&gt;
 &lt;td&gt;RESTful API，JavaScript&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;XML&lt;/td&gt;
 &lt;td&gt;标记语言，支持嵌套，复杂结构&lt;/td&gt;
 &lt;td&gt;数据交换，配置文件，复杂文档&lt;/td&gt;
 &lt;td&gt;SOAP，RSS，配置文件&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;YAML&lt;/td&gt;
 &lt;td&gt;人类可读，简洁语法，易于编写&lt;/td&gt;
 &lt;td&gt;配置文件，人类可读数据交换&lt;/td&gt;
 &lt;td&gt;Docker Compose，Ansible&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;
&lt;p&gt;&lt;strong&gt;其他数据格式&lt;/strong&gt;：&lt;/p&gt;
&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th&gt;数据格式&lt;/th&gt;
 &lt;th&gt;特点&lt;/th&gt;
 &lt;th&gt;适用场景&lt;/th&gt;
 &lt;th&gt;使用服务/应用程序&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td&gt;TOML&lt;/td&gt;
 &lt;td&gt;人类可读，简单，易于编写&lt;/td&gt;
 &lt;td&gt;配置文件，人类可读数据交换&lt;/td&gt;
 &lt;td&gt;Rust，Cargo配置文件&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;CSV&lt;/td&gt;
 &lt;td&gt;文本格式，表格数据，易于导入导出&lt;/td&gt;
 &lt;td&gt;数据导入导出，电子表格&lt;/td&gt;
 &lt;td&gt;Microsoft Excel，Pandas&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;HTML&lt;/td&gt;
 &lt;td&gt;网页标记语言，网页内容描述&lt;/td&gt;
 &lt;td&gt;网页制作，数据抓取，内容展示&lt;/td&gt;
 &lt;td&gt;Web浏览器，网页编辑器&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;EDN&lt;/td&gt;
 &lt;td&gt;可扩展数据表示，Clojure相关&lt;/td&gt;
 &lt;td&gt;Clojure编程，数据交换&lt;/td&gt;
 &lt;td&gt;Clojure，Datomic&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;</description></item><item><title>从 REST api vs gRPC 选型看网络协议</title><link>https://cuisiting.github.io/posts/%E4%BB%8E-rest-api-vs-grpc-%E9%80%89%E5%9E%8B%E7%9C%8B%E7%BD%91%E7%BB%9C%E5%8D%8F%E8%AE%AE/</link><pubDate>Thu, 18 Jan 2024 00:00:00 +0000</pubDate><guid>https://cuisiting.github.io/posts/%E4%BB%8E-rest-api-vs-grpc-%E9%80%89%E5%9E%8B%E7%9C%8B%E7%BD%91%E7%BB%9C%E5%8D%8F%E8%AE%AE/</guid><description>&lt;h1 id="rest-api-与-grpc-的对比"&gt;REST API 与 gRPC 的对比&lt;/h1&gt;
&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th&gt;特性&lt;/th&gt;
 &lt;th&gt;REST API&lt;/th&gt;
 &lt;th&gt;gRPC&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;协议&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;基于 HTTP/1.1 或 HTTP/2&lt;/td&gt;
 &lt;td&gt;基于 HTTP/2&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;数据格式&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;通常使用 JSON 或 XML&lt;/td&gt;
 &lt;td&gt;使用 Protocol Buffers（protobuf）二进制格式&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;性能&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;因为文本格式，解析速度较慢，占用带宽较多&lt;/td&gt;
 &lt;td&gt;二进制序列化，速度快，效率高，占用带宽较小&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;类型安全&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;动态类型，类型安全性较低&lt;/td&gt;
 &lt;td&gt;强类型，通过 protobuf 定义&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;流式支持&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;支持有限，主要是单向&lt;/td&gt;
 &lt;td&gt;支持全双工流式传输（客户端和服务器双向流式）&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;语言支持&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;广泛支持，任何支持 HTTP 的语言都可使用&lt;/td&gt;
 &lt;td&gt;通过代码生成，支持多种语言（如 C++, Java, Go）&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;可读性&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;人类可读，易于调试和测试&lt;/td&gt;
 &lt;td&gt;二进制格式，不易人类阅读，需要工具解析&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;生态系统&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;成熟，拥有大量工具和文档支持&lt;/td&gt;
 &lt;td&gt;相对较新，生态系统正在快速发展&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;典型应用场景&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;公共 API、Web 服务&lt;/td&gt;
 &lt;td&gt;微服务间通信、性能要求高的内部服务&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;
&lt;h1 id="osi-模型各层及其代表性协议"&gt;OSI 模型各层及其代表性协议&lt;/h1&gt;
&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th&gt;层次&lt;/th&gt;
 &lt;th&gt;名称&lt;/th&gt;
 &lt;th&gt;代表性协议或标准&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td&gt;第七层&lt;/td&gt;
 &lt;td&gt;应用层&lt;/td&gt;
 &lt;td&gt;HTTP、FTP、SMTP、DNS、Telnet、SNMP、&lt;strong&gt;gRPC&lt;/strong&gt;、&lt;strong&gt;SSH&lt;/strong&gt;&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;第六层&lt;/td&gt;
 &lt;td&gt;表示层&lt;/td&gt;
 &lt;td&gt;SSL/TLS、ASCII、JPEG、MPEG、加密协议、压缩格式、&lt;strong&gt;SSH&lt;/strong&gt;&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;第五层&lt;/td&gt;
 &lt;td&gt;会话层&lt;/td&gt;
 &lt;td&gt;RPC、SQL、NetBIOS、PPTP、SAP、&lt;strong&gt;SSH&lt;/strong&gt;&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;第四层&lt;/td&gt;
 &lt;td&gt;传输层&lt;/td&gt;
 &lt;td&gt;TCP、UDP、SCTP、SPX&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;第三层&lt;/td&gt;
 &lt;td&gt;网络层&lt;/td&gt;
 &lt;td&gt;IP、ICMP、IGMP、IPSec、ARP、RARP、RIP、OSPF&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;第二层&lt;/td&gt;
 &lt;td&gt;数据链路层&lt;/td&gt;
 &lt;td&gt;Ethernet（以太网）、PPP、HDLC、STP、Frame Relay&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;第一层&lt;/td&gt;
 &lt;td&gt;物理层&lt;/td&gt;
 &lt;td&gt;物理介质（如双绞线、光纤）、IEEE 802.3、RS-232、USB、Bluetooth&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;
&lt;ul&gt;
&lt;li&gt;
&lt;p&gt;&lt;strong&gt;gRPC&lt;/strong&gt;：位于 &lt;strong&gt;应用层（第七层）&lt;/strong&gt;，是一种高性能的开源 RPC 框架，基于 HTTP/2 传输协议，使用 Protocol Buffers 作为接口描述语言和数据序列化方式。&lt;/p&gt;</description></item></channel></rss>