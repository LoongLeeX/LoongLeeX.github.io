<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>特朗普 on Hugo Theme Tailwind Example Site</title><link>https://cuisiting.github.io/tags/%E7%89%B9%E6%9C%97%E6%99%AE/</link><description>Recent content in 特朗普 on Hugo Theme Tailwind Example Site</description><generator>Hugo</generator><language>en</language><copyright>Cuisiting</copyright><lastBuildDate>Thu, 18 Jan 2024 00:00:00 +0000</lastBuildDate><atom:link href="https://cuisiting.github.io/tags/%E7%89%B9%E6%9C%97%E6%99%AE/index.xml" rel="self" type="application/rss+xml"/><item><title>2024 美国大选</title><link>https://cuisiting.github.io/posts/2024-%E7%BE%8E%E5%9B%BD%E5%A4%A7%E9%80%89/</link><pubDate>Thu, 18 Jan 2024 00:00:00 +0000</pubDate><guid>https://cuisiting.github.io/posts/2024-%E7%BE%8E%E5%9B%BD%E5%A4%A7%E9%80%89/</guid><description>&lt;p&gt;美国民主党和共和党的政策对比，以及历届总统的列表和对比：&lt;/p&gt;
&lt;h3 id="政策对比"&gt;政策对比&lt;/h3&gt;
&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th&gt;议题&lt;/th&gt;
 &lt;th&gt;民主党立场&lt;/th&gt;
 &lt;th&gt;共和党立场&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;经济&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;支持渐进税制，加强社会福利，支持最低工资增长&lt;/td&gt;
 &lt;td&gt;支持减税，尤其是对高收入人群，减少政府干预&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;医疗&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;支持全民医保，如《平价医疗法案》&lt;/td&gt;
 &lt;td&gt;反对全民医保，支持私营医疗系统&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;环境&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;支持气候变化政策，推动可再生能源&lt;/td&gt;
 &lt;td&gt;强调能源独立，支持化石燃料，较少关注气候变化&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;枪支控制&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;支持更严格的枪支管制法律&lt;/td&gt;
 &lt;td&gt;保护持枪权，反对过多枪支管制&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;移民&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;支持移民改革，提供非法移民合法化途径&lt;/td&gt;
 &lt;td&gt;强调边境安全，反对非法移民&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;堕胎&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;支持堕胎权&lt;/td&gt;
 &lt;td&gt;反对堕胎，主张保护胎儿生命&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;LGBTQ+权利&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;支持LGBTQ+权利，包括婚姻平等&lt;/td&gt;
 &lt;td&gt;部分支持，但整体较保守，反对同性婚姻&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;教育&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;支持公共教育，加强教育经费投入&lt;/td&gt;
 &lt;td&gt;支持私立学校和家长选择权，反对联邦政府过多干预&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;外交政策&lt;/strong&gt;&lt;/td&gt;
 &lt;td&gt;倾向多边主义，重视国际合作&lt;/td&gt;
 &lt;td&gt;强调美国优先，较为单边主义&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;
&lt;h3 id="历届总统对比"&gt;历届总统对比&lt;/h3&gt;
&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th&gt;任期&lt;/th&gt;
 &lt;th&gt;民主党总统&lt;/th&gt;
 &lt;th&gt;共和党总统&lt;/th&gt;
 &lt;th&gt;政策和主要成就&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td&gt;1789-1797&lt;/td&gt;
 &lt;td&gt;无&lt;/td&gt;
 &lt;td&gt;无&lt;/td&gt;
 &lt;td&gt;乔治·华盛顿（无党派）：美国首任总统，设立总统制度基础&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;1797-1801&lt;/td&gt;
 &lt;td&gt;【候选】托马斯·杰斐逊&lt;/td&gt;
 &lt;td&gt;约翰·亚当斯&lt;/td&gt;
 &lt;td&gt;支持强大中央政府&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;1801-1809&lt;/td&gt;
 &lt;td&gt;托马斯·杰斐逊&lt;/td&gt;
 &lt;td&gt;【候选】约翰·亚当斯&lt;/td&gt;
 &lt;td&gt;路易斯安那购地案&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;1861-1865&lt;/td&gt;
 &lt;td&gt;【候选】斯蒂芬·道格拉斯&lt;/td&gt;
 &lt;td&gt;亚伯拉罕·林肯&lt;/td&gt;
 &lt;td&gt;废除奴隶制，领导美国内战&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;1933-1945&lt;/td&gt;
 &lt;td&gt;富兰克林·罗斯福&lt;/td&gt;
 &lt;td&gt;【候选】赫伯特·胡佛&lt;/td&gt;
 &lt;td&gt;新政，二战领导者&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;1945-1953&lt;/td&gt;
 &lt;td&gt;哈里·杜鲁门&lt;/td&gt;
 &lt;td&gt;【候选】托马斯·杜威&lt;/td&gt;
 &lt;td&gt;二战后重建，朝鲜战争&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;1953-1961&lt;/td&gt;
 &lt;td&gt;【候选】阿德莱·史蒂文森&lt;/td&gt;
 &lt;td&gt;德怀特·艾森豪威尔&lt;/td&gt;
 &lt;td&gt;巩固冷战政策，推进公路建设&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;1961-1963&lt;/td&gt;
 &lt;td&gt;约翰·肯尼迪&lt;/td&gt;
 &lt;td&gt;【候选】理查德·尼克松&lt;/td&gt;
 &lt;td&gt;推进民权运动，处理古巴导弹危机&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;1963-1969&lt;/td&gt;
 &lt;td&gt;林登·约翰逊&lt;/td&gt;
 &lt;td&gt;【候选】巴里·戈德华特&lt;/td&gt;
 &lt;td&gt;通过《民权法案》，推进“伟大社会”政策&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;1969-1974&lt;/td&gt;
 &lt;td&gt;【候选】休伯特·汉弗莱&lt;/td&gt;
 &lt;td&gt;理查德·尼克松&lt;/td&gt;
 &lt;td&gt;访问中国，水门事件&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;1977-1981&lt;/td&gt;
 &lt;td&gt;吉米·卡特&lt;/td&gt;
 &lt;td&gt;【候选】杰拉尔德·福特&lt;/td&gt;
 &lt;td&gt;推动能源政策，处理伊朗人质危机&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;1981-1989&lt;/td&gt;
 &lt;td&gt;【候选】沃尔特·蒙代尔&lt;/td&gt;
 &lt;td&gt;罗纳德·里根&lt;/td&gt;
 &lt;td&gt;里根经济学，冷战结束&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;1993-2001&lt;/td&gt;
 &lt;td&gt;比尔·克林顿&lt;/td&gt;
 &lt;td&gt;【候选】乔治·H·W·布什&lt;/td&gt;
 &lt;td&gt;经济繁荣，推行福利改革&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;2001-2009&lt;/td&gt;
 &lt;td&gt;【候选】阿尔·戈尔&lt;/td&gt;
 &lt;td&gt;乔治·W·布什&lt;/td&gt;
 &lt;td&gt;反恐战争，伊拉克战争&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;2009-2017&lt;/td&gt;
 &lt;td&gt;巴拉克·奥巴马&lt;/td&gt;
 &lt;td&gt;【候选】约翰·麦凯恩&lt;/td&gt;
 &lt;td&gt;《平价医疗法案》，应对金融危机&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;2017-2021&lt;/td&gt;
 &lt;td&gt;【候选】希拉里·克林顿&lt;/td&gt;
 &lt;td&gt;唐纳德·特朗普&lt;/td&gt;
 &lt;td&gt;美国优先政策，减税，贸易战&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;2021-至今&lt;/td&gt;
 &lt;td&gt;乔·拜登&lt;/td&gt;
 &lt;td&gt;【候选】唐纳德·特朗普&lt;/td&gt;
 &lt;td&gt;推行基础设施建设法案，应对COVID-19疫情&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;
&lt;h1&gt;&lt;/h1&gt;
&lt;p&gt;


